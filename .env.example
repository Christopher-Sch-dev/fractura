# FRACTURA — Variables de entorno (plantilla pública)
# Copiar a .env.local y completar con valores reales

# ─── Backend ───────────────────────────────────────────
# Modo de base de datos: duckdb (default) o postgres
DB_MODE=duckdb

# Solo necesario si DB_MODE=postgres
# DATABASE_URL=postgresql://user:password@host:port/db

# API key para ChileCompra (opcional, solo si se usa la API real)
CHILECOMPRA_API_KEY=your_key_here

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=https://fractura.vercel.app,http://localhost:5173

# ─── Frontend ──────────────────────────────────────────
# URL del API backend (default local para desarrollo)
VITE_API_URL=http://127.0.0.1:8000